# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env vars — never commit secrets. Allow a public template.
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase CLI scratch
supabase/.temp/

# Netlify CLI scratch. Keep state.json tracked — it links the repo to the
# Netlify site, not a secret.
.netlify/*
!.netlify/state.json

# Claude Code workspace scratch. Keep launch.json tracked (preview-server
# config, shared with the team); ignore per-user settings and worktrees.
.claude/*
!.claude/launch.json
